{
	"name": "kilocode-magic-context-cli",
	"version": "0.16.1",
	"description": "Kilo Magic Context CLI — setup, doctor, explicit migration, and local packaging",
	"keywords": [
		"kilo",
		"kilocode",
		"kilo-plugin",
		"magic-context",
		"cli",
		"setup",
		"doctor"
	],
	"author": "Kilo Magic Context contributors",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Kilo-Org/kilo-magic-context",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/Kilo-Org/kilo-magic-context#readme",
	"bugs": {
		"url": "https://github.com/Kilo-Org/kilo-magic-context/issues"
	},
	"type": "module",
	"bin": {
		"kilo-magic-context": "dist/index.js",
		"kilocode-magic-context": "dist/index.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "bun build src/index.ts --outfile dist/index.js --target node --format esm --external better-sqlite3",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"lint": "biome check src",
		"format": "biome format --write src",
		"format:check": "biome format src",
		"pack:local": "bun pm pack --destination ../../dist",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@clack/prompts": "^1.1.0",
		"better-sqlite3": "^12.9.0",
		"comment-json": "^4.2.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.0.0",
		"typescript": "^5.8.0"
	},
	"engines": {
		"node": ">=20.12.0"
	}
}
