{
	"name": "kilocode-magic-context",
	"version": "0.16.1",
	"type": "module",
	"description": "Kilo plugin for Magic Context — cross-session memory and context management",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"author": "Kilo Magic Context contributors",
	"license": "MIT",
	"keywords": [
		"kilo",
		"kilocode",
		"plugin",
		"context",
		"memory",
		"ai",
		"llm",
		"prompt-caching",
		"session-history"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Kilo-Org/kilo-magic-context",
		"directory": "packages/plugin"
	},
	"files": [
		"dist",
		"settings",
		"src/tui",
		"src/shared",
		"README.md"
	],
	"scripts": {
		"build": "bun build src/index.ts --outdir dist --target node --format esm --external @kilocode/plugin --external @kilocode/sdk --external @huggingface/transformers --external better-sqlite3 --external bun:sqlite && tsc --emitDeclarationOnly",
		"typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"clean": "rm -rf dist",
		"pack:local": "bun pm pack --destination ../../dist",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@huggingface/transformers": "^4.1.0",
		"@kilocode/plugin": "^7.2.34",
		"@kilocode/sdk": "^7.2.34",
		"ai-tokenizer": "^1.0.6",
		"better-sqlite3": "^12.9.0",
		"comment-json": "^4.2.5",
		"zod": "^4.1.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.0.0",
		"bun-types": "^1.3.10",
		"typescript": "^5.8.0"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./tui": {
			"types": "./src/tui/index.tsx",
			"import": "./src/tui/index.tsx"
		}
	},
	"oc-plugin": [
		"server",
		"tui"
	],
	"kilo-plugin": {
		"id": "kilocode-magic-context",
		"displayName": "Magic Context",
		"description": "Cross-session memory and context management for Kilo",
		"kinds": [
			"server",
			"tui"
		],
		"config": {
			"file": "kilo-magic-context.jsonc",
			"schema": "assets/kilo-magic-context.schema.json"
		},
		"settings": {
			"title": "Magic Context",
			"icon": "brain",
			"entry": "settings/index.html"
		},
		"capabilities": [
			{
				"id": "context.management",
				"label": "Context management",
				"mode": "exclusive"
			}
		],
		"conflicts": [
			{
				"id": "native.compaction",
				"type": "nativeFeature",
				"feature": "native.compaction",
				"severity": "blocking",
				"reason": "Magic Context manages context and cannot run alongside Kilo native auto-summary.",
				"resolutions": [
					{
						"id": "use-plugin",
						"label": "Use Magic Context",
						"recommended": true,
						"actions": [
							{
								"type": "setNativeFeature",
								"feature": "native.compaction.auto",
								"enabled": false
							},
							{
								"type": "setNativeFeature",
								"feature": "native.compaction.prune",
								"enabled": false
							},
							{
								"type": "createPluginConfig"
							},
							{
								"type": "setPluginEnabled",
								"enabled": true
							}
						]
					},
					{
						"id": "keep-native",
						"label": "Keep Kilo Native",
						"actions": [
							{
								"type": "setPluginEnabled",
								"enabled": false
							}
						]
					}
				]
			}
		]
	},
	"peerDependencies": {
		"@kilocode/plugin": ">=7.2.34"
	}
}
