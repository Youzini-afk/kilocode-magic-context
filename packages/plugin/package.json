{
	"name": "kilocode-magic-context",
	"version": "0.16.1",
	"type": "module",
	"description": "Kilo plugin for Magic Context — cross-session memory and context management",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"author": "Kilo Magic Context contributors",
	"license": "MIT",
	"keywords": [
		"kilo",
		"kilocode",
		"plugin",
		"context",
		"memory",
		"ai",
		"llm",
		"prompt-caching",
		"session-history"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Kilo-Org/kilo-magic-context",
		"directory": "packages/plugin"
	},
	"files": [
		"dist",
		"src/tui",
		"src/shared",
		"README.md"
	],
	"scripts": {
		"build": "bun build src/index.ts --outdir dist --target node --format esm --external @kilocode/plugin --external @kilocode/sdk --external @huggingface/transformers --external better-sqlite3 --external bun:sqlite && tsc --emitDeclarationOnly",
		"typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"clean": "rm -rf dist",
		"pack:local": "bun pm pack --destination ../../dist",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@huggingface/transformers": "^4.1.0",
		"@kilocode/plugin": "^7.2.34",
		"@kilocode/sdk": "^7.2.34",
		"ai-tokenizer": "^1.0.6",
		"better-sqlite3": "^12.9.0",
		"comment-json": "^4.2.5",
		"zod": "^4.1.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.0.0",
		"bun-types": "^1.3.10",
		"typescript": "^5.8.0"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./tui": {
			"types": "./src/tui/index.tsx",
			"import": "./src/tui/index.tsx"
		}
	},
	"oc-plugin": [
		"server",
		"tui"
	],
	"peerDependencies": {
		"@kilocode/plugin": ">=7.2.34"
	}
}
